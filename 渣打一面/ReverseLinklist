struct Node {
    int nodeVal;
    Node * next;
    Node(int val = -1, Node* next=nullptr) : nodeVal(val), next(next) {}
};

int PrintNode(Node* node) {
    if (node == nullptr) return -1;

    return node->nodeVal;
}

// 反转链表
// 这是头插法，需要三个指针，pre，cur，next
Node* ReverseLinklist(Node* head) {
    if (head == nullptr || head->next == nullptr) return head;

    // 初始化：pre = nullptr，对应新链表的尾部（旧链表的最前），cur = head
    Node *pre = nullptr, *cur = head;
    while (cur != nullptr) { // 循环条件，当cur == nullptr时，说明cur已经到了旧链表的末尾，反转已经完成
        Node* next = cur->next;  //首先要存储cur->next到next中，防止丢失
        cur->next = pre;  // 把cur->next更新为pre，也就是反转的操作
        pre = cur;  
        cur = next;  // pre = cur， cur = next，移动指针继续反转下一个节点
        // cout << "preval:" << PrintNode(pre) << "curval:" << PrintNode(cur) << "nextval:" << PrintNode(next) << endl;
    }

    return pre;  // 返回pre，因为cur是旧链表的尾部，也就是nullptr，所以pre才是新的头节点
}


int main() {
    Node* lastNode = new Node(0);
    for (int i = 1; i < 5; i++) {
        Node* newNode = new Node(i, lastNode);
        lastNode = newNode;
    }
    
    cout << 1 << endl;
    Node* headNode = lastNode;
    while(lastNode != nullptr) {
        cout << lastNode->nodeVal << "->";
        lastNode = lastNode->next;
    }
    cout << endl << "headval:" << headNode->nodeVal << endl;
    Node* reverseNode = ReverseLinklist(headNode);

    cout << 2 << endl;
    while(reverseNode != nullptr) {
        cout << reverseNode->nodeVal << "->";
        reverseNode = reverseNode->next;
    }

    return 0;
}