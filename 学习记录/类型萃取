#include <iostream>
#include <thread>
#include <vector>
#include <mutex>
#include <memory>
#include <iostream>
#include <type_traits>
#include <string>

using namespace std;

// 判断类型
template <class T>
auto isInt(T t) {
    return is_same_v<T, int>;
}

// 根据类型做不同操作，需要constexpr修饰is_same_v所在的if语句，保证其为编译期求值
template <class T>
auto diffType(T t) {
    if constexpr (is_same_v<T, int>) {
        return t+1;
    } else {
        return t.substr(1);
    }
}

// 如果使用decltype，最好decay_t<decltype(t)>，防止推断错误（const int &）
template <class T>
auto diffType1(const T &t) {
    if constexpr (is_same_v<decay_t<decltype(t), int>) { 
        return t+1;
    } else {
        return t.substr(1);
    }
}

// typename, 指示编译器这个是类型，而不是成员变量，只有涉及模板参数才需要
template <class T>
auto diffType2(const T &t) {
    if constexpr (is_same_v<typename T::value_type, int>) { 
        return t+1;
    } else {
        return t.substr(1);
    }
}

int main() {
    int a = 10;
    string s = "123456";

    cout << isInt(a) << endl;

    cout << "diff type int:" << diffType(a) << '\n' << "diff type str:" << diffType(s) << endl;

    return 0;
}